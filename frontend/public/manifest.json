{
  "manifest_version": 3,
  "name": "Pattern Detector Pro",
  "version": "1.0.0",
  "description": "Detects fake scarcity, urgency, and social proof on websites using AI",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "http://localhost:5000/*", 
    "<all_urls>"
  ],
  "action": {
    "default_popup": "index.html",
    "default_title": "Pattern Detector Pro"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}